# Database (PostgreSQL preferred)
DB_NAME=pharmasign
DB_USER=pharmasign
DB_PASSWORD=pharmasignpass
DB_HOST=localhost
DB_PORT=5432

# JWT
SECRET_KEY=django-insecure-your-secret-key-change-in-production
# Supports plain integers using the default unit, or suffixes: m, h, d.
JWT_ACCESS_TOKEN_LIFETIME=5h
JWT_REFRESH_TOKEN_LIFETIME=7d

# Media
MEDIA_URL=/media/
MEDIA_ROOT=media/
PHARMASIGN_MAX_IMAGE_UPLOAD_BYTES=5242880
PHARMASIGN_MAX_AUDIO_UPLOAD_BYTES=15728640
PHARMASIGN_MAX_VIDEO_UPLOAD_BYTES=52428800

# Backend audio transcription
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_SIGN_MODEL=gemini-2.5-flash
MAX_AUDIO_UPLOAD_SIZE_MB=10

# OTP delivery
# DEBUG=True returns debug_otp in OTP responses for local development.
# In production, set DEBUG=False and configure a real provider before enabling this.
OTP_DELIVERY_PROVIDER_CONFIGURED=False

# Runtime mode / debug
# PHARMASIGN_ENV=development defaults DEBUG to True when DEBUG is omitted.
# PHARMASIGN_ENV=production defaults DEBUG to False when DEBUG is omitted.
PHARMASIGN_ENV=development
DEBUG=True

# Allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS origins for mobile/web clients
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:8082,http://localhost:19006,http://127.0.0.1:8081,http://127.0.0.1:8082,http://127.0.0.1:19006
